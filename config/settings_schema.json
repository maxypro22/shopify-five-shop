[
  {
    "name": "theme_info",
    "theme_name": "Shop Five",
    "theme_version": "1.0.0",
    "theme_author": "Shop Five",
    "theme_documentation_url": "https://shopify.dev/themes",
    "theme_support_url": "https://help.shopify.com"
  },
  {
    "name": "Branding",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo",
        "info": "If empty, the bundled Shop Five logo is used."
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 60,
        "max": 240,
        "step": 10,
        "unit": "px",
        "label": "Logo max width",
        "default": 130
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "64 x 64px .png recommended"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent color",
        "default": "#4f46e5"
      },
      {
        "type": "select",
        "id": "default_color_mode",
        "label": "Default color mode",
        "info": "Visitors can switch any time; their choice is remembered.",
        "default": "light",
        "options": [
          { "value": "light", "label": "Light" },
          { "value": "dark", "label": "Dark" }
        ]
      }
    ]
  },
  {
    "name": "Animations",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_animations",
        "label": "Enable scroll animations",
        "default": true
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold",
        "info": "In your store currency (QAR). Set 0 to hide the progress bar.",
        "default": 200
      }
    ]
  },
  {
    "name": "Mobile app",
    "settings": [
      { "type": "url", "id": "app_store_url", "label": "App Store link (iOS)" },
      { "type": "url", "id": "play_store_url", "label": "Google Play link (Android)" }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      { "type": "url", "id": "social_instagram", "label": "Instagram" },
      { "type": "url", "id": "social_tiktok", "label": "TikTok" },
      { "type": "url", "id": "social_twitter", "label": "X (Twitter)" },
      { "type": "url", "id": "social_facebook", "label": "Facebook" },
      { "type": "url", "id": "social_snapchat", "label": "Snapchat" },
      { "type": "url", "id": "social_whatsapp", "label": "WhatsApp link", "info": "Example: https://wa.me/97400000000" },
      { "type": "url", "id": "social_youtube", "label": "YouTube" }
    ]
  }
]
