{
  "current": {
    "color_accent": "#4f46e5",
    "default_color_mode": "light",
    "logo_width": 130,
    "enable_animations": true,
    "free_shipping_threshold": 200,
    "sections": {
      "announcement-ticker": {
        "type": "announcement-ticker",
        "blocks": {
          "a1": { "type": "announcement", "settings": { "text": "Free shipping on orders over QAR 200", "icon": "truck" } },
          "a2": { "type": "announcement", "settings": { "text": "Price Smash — up to 50% off", "icon": "fire" } },
          "a3": { "type": "announcement", "settings": { "text": "New arrivals every week", "icon": "sparkle" } },
          "a4": { "type": "announcement", "settings": { "text": "Cash on delivery available in Qatar", "icon": "shield" } }
        },
        "block_order": ["a1", "a2", "a3", "a4"]
      },
      "footer": {
        "type": "footer",
        "blocks": {
          "menu1": { "type": "link_list", "settings": { "heading": "Shop", "menu": "main-menu" } },
          "menu2": { "type": "link_list", "settings": { "heading": "Support", "menu": "footer" } },
          "news": { "type": "newsletter" }
        },
        "block_order": ["menu1", "menu2", "news"]
      }
    }
  }
}
