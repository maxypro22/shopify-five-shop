<section class="section-spacing">
  <div class="page-width">
    <div class="trust-grid">
      {%- for block in section.blocks -%}
        <div class="trust-card reveal" style="--reveal-delay: {{ forloop.index0 | times: 0.08 }}s" {{ block.shopify_attributes }}>
          <span class="trust-card__icon">{% render 'icon', icon: block.settings.icon %}</span>
          <h3 class="trust-card__title">{{ block.settings.title | escape }}</h3>
          <p class="trust-card__text">{{ block.settings.text | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust badges",
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "truck",
          "options": [
            { "value": "truck", "label": "Delivery truck" },
            { "value": "refresh", "label": "Returns" },
            { "value": "shield", "label": "Shield" },
            { "value": "headset", "label": "Support" },
            { "value": "payment", "label": "Payment card" },
            { "value": "gift", "label": "Gift" },
            { "value": "box", "label": "Package" },
            { "value": "sparkle", "label": "Sparkle" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Fast delivery" },
        { "type": "text", "id": "text", "label": "Text", "default": "Across Qatar in 1–3 business days." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust badges",
      "blocks": [
        { "type": "badge", "settings": { "icon": "truck", "title": "Fast delivery", "text": "Across Qatar in 1–3 business days." } },
        { "type": "badge", "settings": { "icon": "refresh", "title": "Easy returns", "text": "14-day hassle-free returns." } },
        { "type": "badge", "settings": { "icon": "shield", "title": "Secure checkout", "text": "Your payment details stay protected." } },
        { "type": "badge", "settings": { "icon": "headset", "title": "Real support", "text": "We reply fast — WhatsApp & email." } }
      ]
    }
  ]
}
{% endschema %}
