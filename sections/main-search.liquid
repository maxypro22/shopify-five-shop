<div class="page-hero">
  <div class="page-width">
    <h1 class="reveal">
      {%- if search.performed -%}
        {{ 'general.search.results_title' | t: terms: search.terms }}
      {%- else -%}
        {{ 'general.search.title' | t }}
      {%- endif -%}
    </h1>
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-page__form reveal">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}" aria-label="{{ 'general.search.placeholder' | t }}">
      <input type="hidden" name="options[prefix]" value="last">
      <button type="submit" aria-label="{{ 'general.search.submit' | t }}">
        {% render 'icon', icon: 'search' %}
      </button>
    </form>
    {%- if search.performed -%}
      <p class="page-hero__subtitle">{{ 'general.search.results_count' | t: count: search.results_count }}</p>
    {%- endif -%}
  </div>
</div>

<div class="page-width" style="padding-block: 3.2rem 5rem;">
  {%- if search.performed -%}
    {%- if search.results_count > 0 -%}
      {%- paginate search.results by 24 -%}
        <div class="product-grid" style="--grid-cols: 4">
          {%- for item in search.results -%}
            {%- case item.object_type -%}
              {%- when 'product' -%}
                {% render 'product-card', card_product: item, index: forloop.index0 %}
              {%- when 'article' -%}
                <article class="article-card reveal">
                  {%- if item.image -%}
                    <div class="article-card__media">
                      {{ item.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: item.title | escape }}
                    </div>
                  {%- endif -%}
                  <div class="article-card__content">
                    <h3 class="article-card__title"><a href="{{ item.url }}">{{ item.title | escape }}</a></h3>
                  </div>
                </article>
              {%- when 'page' -%}
                <article class="trust-card reveal">
                  <h3 class="trust-card__title"><a href="{{ item.url }}">{{ item.title | escape }}</a></h3>
                  <p class="trust-card__text">{{ item.content | strip_html | truncate: 120 }}</p>
                </article>
            {%- endcase -%}
          {%- endfor -%}
        </div>
        {% render 'pagination', paginate: paginate %}
      {%- endpaginate -%}
    {%- else -%}
      <div class="collection-empty">
        {% render 'icon', icon: 'search' %}
        <h2>{{ 'general.search.no_results_title' | t }}</h2>
        <p class="text-2">{{ 'general.search.no_results' | t: terms: search.terms }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary" style="margin-block-start: 2rem;">
          {{ 'cart.general.continue_shopping' | t }}
        </a>
      </div>
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Search results",
  "settings": []
}
{% endschema %}
