<div id="CartDrawer" class="drawer cart-drawer" role="dialog" aria-modal="true" aria-hidden="true" aria-label="{{ 'cart.general.title' | t }}">
  <div class="drawer__header">
    <h2 class="drawer__title">
      {{ 'cart.general.title' | t }}
      <span class="cart-drawer__count" data-cart-count data-count="{{ cart.item_count }}">{{ cart.item_count }}</span>
    </h2>
    <button type="button" class="drawer__close" data-drawer-close aria-label="{{ 'general.accessibility.close' | t }}">
      {% render 'icon', icon: 'close' %}
    </button>
  </div>

  {%- if settings.free_shipping_threshold > 0 and cart.item_count > 0 -%}
    {%- liquid
      assign threshold = settings.free_shipping_threshold | times: 100
      assign remaining = threshold | minus: cart.total_price
      assign remaining_money = remaining | money
      assign progress = cart.total_price | times: 100.0 | divided_by: threshold | at_most: 100
    -%}
    <div class="free-shipping-bar">
      {%- if remaining > 0 -%}
        <p class="free-shipping-bar__label">
          {% render 'icon', icon: 'truck' %}
          <span>{{ 'cart.free_shipping.remaining_html' | t: amount: remaining_money }}</span>
        </p>
      {%- else -%}
        <p class="free-shipping-bar__label is-unlocked">
          {% render 'icon', icon: 'check-circle' %}
          <span>{{ 'cart.free_shipping.unlocked' | t }}</span>
        </p>
      {%- endif -%}
      <div class="free-shipping-bar__track">
        <div class="free-shipping-bar__fill" style="--progress: {{ progress }}%"></div>
      </div>
    </div>
  {%- endif -%}

  <div class="drawer__body">
    {%- if cart.item_count == 0 -%}
      <div class="cart-drawer__empty">
        {% render 'icon', icon: 'cart' %}
        <h3 class="cart-drawer__empty-title">{{ 'cart.general.empty' | t }}</h3>
        <p class="text-2">{{ 'cart.general.empty_text' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary" data-drawer-close>
          {{ 'cart.general.continue_shopping' | t }}
        </a>
      </div>
    {%- else -%}
      <ul class="cart-items" role="list">
        {%- for item in cart.items -%}
          <li class="cart-item">
            <a href="{{ item.url }}" class="cart-item__media">
              {%- if item.image -%}
                {{ item.image | image_url: width: 240 | image_tag: loading: 'lazy', alt: item.title | escape }}
              {%- endif -%}
            </a>
            <div class="cart-item__details">
              <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title | escape }}</a>
              {%- unless item.product.has_only_default_variant -%}
                <p class="cart-item__meta">{{ item.variant.title | escape }}</p>
              {%- endunless -%}
              {%- for discount in item.line_level_discount_allocations -%}
                <p class="cart-item__meta" style="color: var(--color-success);">{{ discount.discount_application.title | escape }}</p>
              {%- endfor -%}
              <div class="cart-item__bottom">
                <div class="quantity">
                  <button type="button" class="quantity__button" data-quantity-change="down" aria-label="{{ 'cart.items.decrease' | t }}">
                    {% render 'icon', icon: 'minus' %}
                  </button>
                  <input type="number" class="quantity__input" value="{{ item.quantity }}" min="0" data-line="{{ forloop.index }}" aria-label="{{ 'cart.items.quantity' | t }}">
                  <button type="button" class="quantity__button" data-quantity-change="up" aria-label="{{ 'cart.items.increase' | t }}">
                    {% render 'icon', icon: 'plus' %}
                  </button>
                </div>
                <span class="cart-item__price">
                  {%- if item.original_line_price != item.final_line_price -%}
                    <s>{{ item.original_line_price | money }}</s>
                  {%- endif -%}
                  {{ item.final_line_price | money }}
                </span>
              </div>
              <button type="button" class="cart-item__remove" data-cart-remove="{{ forloop.index }}">
                {% render 'icon', icon: 'trash' %}
                {{ 'cart.items.remove' | t }}
              </button>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>

  {%- if cart.item_count > 0 -%}
    <div class="drawer__footer">
      {%- if cart.cart_level_discount_applications.size > 0 -%}
        {%- for discount in cart.cart_level_discount_applications -%}
          <div class="cart-summary__row" style="color: var(--color-success);">
            <span>{{ discount.title | escape }}</span>
            <span>-{{ discount.total_allocated_amount | money }}</span>
          </div>
        {%- endfor -%}
      {%- endif -%}
      <div class="cart-summary__row cart-summary__row--total">
        <span>{{ 'cart.general.subtotal' | t }}</span>
        <span>{{ cart.total_price | money }}</span>
      </div>
      <a href="/checkout" class="btn btn--primary btn--full">
        {{ 'cart.general.checkout' | t }}
      </a>
      <a href="{{ routes.cart_url }}" class="btn btn--secondary btn--full" style="margin-block-start: 1rem;">
        {{ 'cart.general.view_cart' | t }}
      </a>
      <p class="cart-summary__note">{{ 'cart.general.taxes_note' | t }}</p>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Cart drawer",
  "settings": []
}
{% endschema %}
