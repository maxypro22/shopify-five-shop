{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign on_sale = false
  if current_variant.compare_at_price > current_variant.price
    assign on_sale = true
    assign discount = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round
  endif
-%}

<div class="page-width">
  <div class="product-layout">
    {%- comment -%} Gallery {%- endcomment -%}
    <div class="product-gallery reveal" data-product-gallery>
      <div class="product-gallery__main" data-gallery-main>
        {%- if on_sale -%}
          <span class="badge badge--sale">-{{ discount }}%</span>
        {%- endif -%}
        {%- assign featured = current_variant.featured_media | default: product.featured_media -%}
        {%- if featured != blank -%}
          {{ featured | image_url: width: 1200 | image_tag: widths: '600, 900, 1200', sizes: '(min-width: 990px) 50vw, 100vw', alt: featured.alt | default: product.title | escape, preload: true }}
        {%- else -%}
          <div class="hero__media-placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
        {%- endif -%}
      </div>
      {%- if product.media.size > 1 -%}
        <div class="product-gallery__thumbs">
          {%- for media in product.media -%}
            <button type="button"
              class="product-gallery__thumb{% if media.id == featured.id %} is-active{% endif %}"
              data-gallery-thumb
              data-media-id="{{ media.id }}"
              data-full-src="{{ media | image_url: width: 1200 }}"
              aria-label="{{ 'products.product.media_thumbnail' | t: index: forloop.index }}">
              {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt | escape }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Info {%- endcomment -%}
    <div class="product-info reveal" style="--reveal-delay: 0.1s">
      {%- if product.vendor != blank and product.vendor != shop.name -%}
        <p class="product-info__vendor">{{ product.vendor | escape }}</p>
      {%- endif -%}
      <h1 class="product-info__title">{{ product.title | escape }}</h1>

      <div class="product-info__price-row">
        {% render 'price', product: product, size: 'lg' %}
        {%- if on_sale -%}
          <span class="badge badge--sale">{{ 'products.product.sale' | t }}</span>
        {%- endif -%}
      </div>
      <p class="product-info__tax">{{ 'products.product.tax_note' | t }}</p>

      {%- form 'product', product, data-product-form: '', data-product-id: product.id -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">

        {%- unless product.has_only_default_variant -%}
          <div class="variant-picker" data-variant-picker data-product-id="{{ product.id }}">
            {%- for option in product.options_with_values -%}
              <fieldset class="variant-picker__group" style="border: none;">
                <legend class="variant-picker__label">
                  {{ option.name | escape }}
                </legend>
                <div class="variant-picker__options">
                  {%- for value in option.values -%}
                    <span class="variant-pill">
                      <input type="radio"
                        id="Option-{{ option.position }}-{{ forloop.index }}"
                        name="options[{{ option.name | escape }}]"
                        value="{{ value | escape }}"
                        {% if option.selected_value == value %}checked{% endif %}>
                      <label for="Option-{{ option.position }}-{{ forloop.index }}">{{ value | escape }}</label>
                    </span>
                  {%- endfor -%}
                </div>
              </fieldset>
            {%- endfor -%}
            <script type="application/json" data-product-json>{{ product | json }}</script>
          </div>
        {%- endunless -%}

        <div class="variant-picker__label">{{ 'products.product.quantity' | t }}</div>
        <div class="quantity quantity--lg">
          <button type="button" class="quantity__button" data-qty-static="down" aria-label="{{ 'cart.items.decrease' | t }}">
            {% render 'icon', icon: 'minus' %}
          </button>
          <input type="number" class="quantity__input" name="quantity" value="1" min="1" aria-label="{{ 'products.product.quantity' | t }}">
          <button type="button" class="quantity__button" data-qty-static="up" aria-label="{{ 'cart.items.increase' | t }}">
            {% render 'icon', icon: 'plus' %}
          </button>
        </div>

        <div class="product-form__buttons">
          <button type="submit" class="btn btn--primary btn--full" data-add-to-cart {% unless current_variant.available %}disabled{% endunless %}>
            {% render 'icon', icon: 'cart' %}
            <span data-add-to-cart-text>
              {%- if current_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </span>
          </button>
          {{ form | payment_button }}
        </div>
      {%- endform -%}

      {%- if section.settings.show_pickup_hint and current_variant.available -%}
        <div class="pickup-hint">
          {% render 'icon', icon: 'check-circle' %}
          {{ 'products.product.in_stock' | t }}
        </div>
      {%- endif -%}

      <div class="product-info__accordions">
        {%- if product.description != blank -%}
          <details class="accordion" open>
            <summary class="accordion__summary">
              <span>{% render 'icon', icon: 'info', class: 'icon--label' %}{{ 'products.product.description' | t }}</span>
              {% render 'icon', icon: 'chevron-down', class: 'icon--caret' %}
            </summary>
            <div class="accordion__content rte">{{ product.description }}</div>
          </details>
        {%- endif -%}
        {%- if section.settings.shipping_text != blank -%}
          <details class="accordion">
            <summary class="accordion__summary">
              <span>{% render 'icon', icon: 'truck', class: 'icon--label' %}{{ 'products.product.shipping' | t }}</span>
              {% render 'icon', icon: 'chevron-down', class: 'icon--caret' %}
            </summary>
            <div class="accordion__content">{{ section.settings.shipping_text }}</div>
          </details>
        {%- endif -%}
        {%- if section.settings.returns_text != blank -%}
          <details class="accordion">
            <summary class="accordion__summary">
              <span>{% render 'icon', icon: 'refresh', class: 'icon--label' %}{{ 'products.product.returns' | t }}</span>
              {% render 'icon', icon: 'chevron-down', class: 'icon--caret' %}
            </summary>
            <div class="accordion__content">{{ section.settings.returns_text }}</div>
          </details>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product page",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_pickup_hint",
      "label": "Show 'in stock' hint",
      "default": true
    },
    {
      "type": "richtext",
      "id": "shipping_text",
      "label": "Shipping accordion",
      "default": "<p>Delivery to all areas of Doha within 4 hours — توصيل لجميع مناطق الدوحة خلال أربع ساعات فقط. Free shipping on orders over QAR 200. Cash on delivery available. GCC-wide delivery also available.</p>"
    },
    {
      "type": "richtext",
      "id": "returns_text",
      "label": "Returns accordion",
      "default": "<p>Changed your mind? You have 14 days to return unworn items in original packaging. See our refund policy for full details.</p>"
    }
  ]
}
{% endschema %}
