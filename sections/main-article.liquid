<div class="page-hero">
  <div class="page-width">
    <nav class="collection-banner__breadcrumb" aria-label="{{ 'general.breadcrumb.label' | t }}">
      <a href="{{ routes.root_url }}">{{ 'general.breadcrumb.home' | t }}</a>
      {% render 'icon', icon: 'chevron-right' %}
      <a href="{{ blog.url }}">{{ blog.title | escape }}</a>
    </nav>
    <h1 class="reveal">{{ article.title | escape }}</h1>
    <p class="page-hero__subtitle">
      {{ article.published_at | date: format: 'month_day_year' }}
      {%- if article.author != blank %} · {{ article.author | escape }}{% endif -%}
    </p>
  </div>
</div>

<div class="page-width article-page__hero">
  {%- if article.image -%}
    {{ article.image | image_url: width: 1600 | image_tag: widths: '800, 1200, 1600', sizes: '100vw', alt: article.title | escape }}
  {%- endif -%}
</div>

<div class="page-width">
  <article class="page-content rte reveal">
    {{ article.content }}
  </article>
</div>

{% schema %}
{
  "name": "Article",
  "settings": []
}
{% endschema %}
