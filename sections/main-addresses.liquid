<div class="page-width customer-page">
  <div class="section-header">
    <div>
      <span class="section-header__eyebrow">{{ 'customer.account.title' | t }}</span>
      <h1>{{ 'customer.addresses.title' | t }}</h1>
    </div>
    <a href="{{ routes.account_url }}" class="btn btn--secondary btn--sm">{{ 'customer.order.back' | t }}</a>
  </div>

  <div class="account-grid" style="grid-template-columns: 1fr; max-width: 64rem;">
    <div class="account-panel reveal">
      <h2>{{ 'customer.addresses.add_new' | t }}</h2>
      {%- form 'customer_address', customer.new_address -%}
        <div class="form-grid form-grid--2col">
          <div class="field">
            <label class="field__label" for="AddressFirstName">{{ 'customer.general.first_name' | t }}</label>
            <input class="field__input" type="text" id="AddressFirstName" name="address[first_name]" value="{{ form.first_name }}">
          </div>
          <div class="field">
            <label class="field__label" for="AddressLastName">{{ 'customer.general.last_name' | t }}</label>
            <input class="field__input" type="text" id="AddressLastName" name="address[last_name]" value="{{ form.last_name }}">
          </div>
          <div class="field field--full">
            <label class="field__label" for="AddressAddress1">{{ 'customer.addresses.address1' | t }}</label>
            <input class="field__input" type="text" id="AddressAddress1" name="address[address1]" value="{{ form.address1 }}">
          </div>
          <div class="field">
            <label class="field__label" for="AddressCity">{{ 'customer.addresses.city' | t }}</label>
            <input class="field__input" type="text" id="AddressCity" name="address[city]" value="{{ form.city }}">
          </div>
          <div class="field">
            <label class="field__label" for="AddressCountry">{{ 'customer.addresses.country' | t }}</label>
            <div class="select-wrapper">
              <select class="field__select" id="AddressCountry" name="address[country]" data-default="{{ form.country }}">
                {{ all_country_option_tags }}
              </select>
              {% render 'icon', icon: 'chevron-down' %}
            </div>
          </div>
          <div class="field">
            <label class="field__label" for="AddressPhone">{{ 'contact.form.phone' | t }}</label>
            <input class="field__input" type="tel" id="AddressPhone" name="address[phone]" value="{{ form.phone }}">
          </div>
        </div>
        <button type="submit" class="btn btn--primary">{{ 'customer.addresses.add_new' | t }}</button>
      {%- endform -%}
    </div>

    {%- paginate customer.addresses by 6 -%}
      {%- for address in customer.addresses -%}
        <div class="account-panel reveal">
          {%- if address == customer.default_address -%}
            <span class="badge badge--new" style="margin-block-end: 1.2rem;">{{ 'customer.addresses.default' | t }}</span>
          {%- endif -%}
          <div class="address-card" style="border: none; padding: 0; margin: 0;">
            {{ address | format_address }}
            <div class="address-card__actions">
              <button type="button" onclick="document.getElementById('EditAddress_{{ address.id }}').toggleAttribute('hidden')">{{ 'customer.addresses.edit' | t }}</button>
              {%- form 'customer_address', address -%}
                <button type="submit" name="_method" value="delete" onclick="return confirm('{{ 'customer.addresses.delete_confirm' | t }}')">{{ 'customer.addresses.delete' | t }}</button>
              {%- endform -%}
            </div>
          </div>
          <div id="EditAddress_{{ address.id }}" hidden style="margin-block-start: 2rem;">
            {%- form 'customer_address', address -%}
              <div class="form-grid form-grid--2col">
                <div class="field">
                  <label class="field__label">{{ 'customer.general.first_name' | t }}</label>
                  <input class="field__input" type="text" name="address[first_name]" value="{{ form.first_name }}">
                </div>
                <div class="field">
                  <label class="field__label">{{ 'customer.general.last_name' | t }}</label>
                  <input class="field__input" type="text" name="address[last_name]" value="{{ form.last_name }}">
                </div>
                <div class="field field--full">
                  <label class="field__label">{{ 'customer.addresses.address1' | t }}</label>
                  <input class="field__input" type="text" name="address[address1]" value="{{ form.address1 }}">
                </div>
                <div class="field">
                  <label class="field__label">{{ 'customer.addresses.city' | t }}</label>
                  <input class="field__input" type="text" name="address[city]" value="{{ form.city }}">
                </div>
                <div class="field">
                  <label class="field__label">{{ 'customer.addresses.country' | t }}</label>
                  <div class="select-wrapper">
                    <select class="field__select" name="address[country]" data-default="{{ form.country }}">
                      {{ all_country_option_tags }}
                    </select>
                    {% render 'icon', icon: 'chevron-down' %}
                  </div>
                </div>
                <div class="field field--full">
                  <label class="facet-checkbox">
                    <input type="checkbox" name="address[default]" {% if address == customer.default_address %}checked{% endif %}>
                    <span>{{ 'customer.addresses.set_default' | t }}</span>
                  </label>
                </div>
              </div>
              <button type="submit" class="btn btn--primary btn--sm">{{ 'customer.addresses.save' | t }}</button>
            {%- endform -%}
          </div>
        </div>
      {%- endfor -%}
      {% render 'pagination', paginate: paginate %}
    {%- endpaginate -%}
  </div>
</div>

<script>
  // Preselect saved country in country dropdowns
  document.querySelectorAll('select[data-default]').forEach(function (select) {
    var def = select.getAttribute('data-default');
    if (!def) { def = 'Qatar'; }
    Array.from(select.options).forEach(function (opt) {
      if (opt.value === def) { opt.selected = true; }
    });
  });
</script>

{% schema %}
{
  "name": "Addresses",
  "settings": []
}
{% endschema %}
