<div class="page-width customer-page">
  <div class="customer-card reveal">
    <h1>{{ 'customer.reset.title' | t }}</h1>
    <p>{{ 'customer.reset.subtitle' | t }}</p>

    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}
        <div class="form-status form-status--error">{{ form.errors | default_errors }}</div>
      {%- endif -%}
      <div class="field">
        <label class="field__label" for="ResetPassword">{{ 'customer.reset.new_password' | t }}</label>
        <input class="field__input" type="password" id="ResetPassword" name="customer[password]" autocomplete="new-password" required>
      </div>
      <div class="field">
        <label class="field__label" for="ResetPasswordConfirm">{{ 'customer.reset.confirm_password' | t }}</label>
        <input class="field__input" type="password" id="ResetPasswordConfirm" name="customer[password_confirmation]" autocomplete="new-password" required>
      </div>
      <button type="submit" class="btn btn--primary btn--full">{{ 'customer.reset.submit' | t }}</button>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Reset password",
  "settings": []
}
{% endschema %}
