<div class="password-page">
  <div class="password-page__box">
    <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}">
    <h1 class="h1" style="margin-block-end: 1.2rem;">{{ section.settings.heading | escape }}</h1>
    <p class="text-2" style="margin-block-end: 3rem;">{{ section.settings.text | escape }}</p>
    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <p class="form-status form-status--error">{{ 'general.password.error' | t }}</p>
      {%- endif -%}
      <div class="newsletter-form" style="max-width: 40rem; margin-inline: auto;">
        <input type="password" name="password" placeholder="{{ 'general.password.placeholder' | t }}" aria-label="{{ 'general.password.placeholder' | t }}">
        <button type="submit" class="btn btn--primary btn--sm">{{ 'general.password.submit' | t }}</button>
      </div>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Password page",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Something big is coming" },
    { "type": "text", "id": "text", "label": "Text", "default": "Shop Five is launching soon. Premium fashion, fragrances and watches — delivered across Qatar." }
  ]
}
{% endschema %}
