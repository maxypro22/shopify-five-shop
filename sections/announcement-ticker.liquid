{%- if section.blocks.size > 0 -%}
  <div class="announcement-ticker" style="--ticker-speed: {{ section.settings.speed }}s" role="region" aria-label="{{ 'sections.ticker.label' | t }}">
    <div class="announcement-ticker__track" data-marquee>
      <div class="announcement-ticker__group" data-marquee-group>
        {%- for block in section.blocks -%}
          <span class="announcement-ticker__item" {{ block.shopify_attributes }}>
            {% render 'icon', icon: block.settings.icon %}
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
            {%- else -%}
              {{ block.settings.text | escape }}
            {%- endif -%}
          </span>
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement ticker",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Scroll speed (lower = faster)",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free shipping on orders over QAR 200"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "truck",
          "options": [
            { "value": "truck", "label": "Truck" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "fire", "label": "Fire" },
            { "value": "tag", "label": "Tag" },
            { "value": "gift", "label": "Gift" },
            { "value": "shield", "label": "Shield" },
            { "value": "refresh", "label": "Returns" },
            { "value": "headset", "label": "Support" }
          ]
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "announcement", "settings": { "text": "Free shipping on orders over QAR 200", "icon": "truck" } },
      { "type": "announcement", "settings": { "text": "Price Smash — up to 50% off", "icon": "fire" } },
      { "type": "announcement", "settings": { "text": "New arrivals every week", "icon": "sparkle" } },
      { "type": "announcement", "settings": { "text": "Cash on delivery available in Qatar", "icon": "shield" } }
    ]
  }
}
{% endschema %}
