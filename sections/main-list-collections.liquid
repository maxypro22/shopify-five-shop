<div class="page-hero">
  <div class="page-width">
    <span class="section-header__eyebrow" style="justify-content: center;">{{ shop.name }}</span>
    <h1 class="reveal">{{ section.settings.heading | default: page_title | escape }}</h1>
    {%- if section.settings.subtitle != blank -%}
      <p class="page-hero__subtitle reveal">{{ section.settings.subtitle | escape }}</p>
    {%- endif -%}
  </div>
</div>

<div class="page-width">
  {%- paginate collections by 16 -%}
    <div class="collections-list-grid">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="category-card reveal" style="--reveal-delay: {{ forloop.index0 | modulo: 4 | times: 0.06 }}s">
          {%- if collection.featured_image != blank -%}
            {{ collection.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', widths: '350, 500, 700', sizes: '(min-width: 990px) 25vw, 50vw', alt: collection.title | escape }}
          {%- else -%}
            <div class="category-card__placeholder">{{ 'collection-1' | placeholder_svg_tag }}</div>
          {%- endif -%}
          <div class="category-card__content">
            <div>
              <h2 class="category-card__title">{{ collection.title | escape }}</h2>
              <span class="category-card__count">{{ 'sections.categories.products_count' | t: count: collection.all_products_count }}</span>
            </div>
            <span class="category-card__arrow">{% render 'icon', icon: 'arrow-right' %}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
    {% render 'pagination', paginate: paginate %}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Collections list",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "All categories" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Browse everything we carry — fashion, fragrances, watches and more." }
  ]
}
{% endschema %}
