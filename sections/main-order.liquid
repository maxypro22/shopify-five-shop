<div class="page-width customer-page">
  <div class="section-header">
    <div>
      <span class="section-header__eyebrow">{{ 'customer.account.title' | t }}</span>
      <h1>{{ 'customer.order.title' | t: name: order.name }}</h1>
      <p class="text-2">{{ order.created_at | date: format: 'month_day_year' }}</p>
    </div>
    <a href="{{ routes.account_url }}" class="btn btn--secondary btn--sm">{{ 'customer.order.back' | t }}</a>
  </div>

  <div class="account-grid">
    <div class="account-panel reveal">
      <h2>{{ 'customer.order.items' | t }}</h2>
      <div style="overflow-x: auto;">
        <table class="orders-table">
          <thead>
            <tr>
              <th>{{ 'customer.order.product' | t }}</th>
              <th>{{ 'customer.order.quantity' | t }}</th>
              <th>{{ 'customer.orders.total' | t }}</th>
            </tr>
          </thead>
          <tbody>
            {%- for line_item in order.line_items -%}
              <tr>
                <td>
                  {{ line_item.title | escape }}
                  {%- if line_item.variant.title != 'Default Title' -%}
                    <br><small class="text-3">{{ line_item.variant.title | escape }}</small>
                  {%- endif -%}
                </td>
                <td>{{ line_item.quantity }}</td>
                <td>{{ line_item.final_line_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
          <tfoot>
            <tr>
              <td colspan="2"><strong>{{ 'cart.general.subtotal' | t }}</strong></td>
              <td>{{ order.line_items_subtotal_price | money }}</td>
            </tr>
            {%- for shipping_method in order.shipping_methods -%}
              <tr>
                <td colspan="2">{{ 'customer.order.shipping' | t }} ({{ shipping_method.title }})</td>
                <td>{{ shipping_method.price | money }}</td>
              </tr>
            {%- endfor -%}
            <tr>
              <td colspan="2"><strong>{{ 'customer.orders.total' | t }}</strong></td>
              <td><strong>{{ order.total_price | money }}</strong></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <div class="account-panel reveal" style="--reveal-delay: 0.1s">
      <h2>{{ 'customer.order.shipping_address' | t }}</h2>
      <div class="address-card">
        {%- if order.shipping_address -%}
          {{ order.shipping_address | format_address }}
        {%- else -%}
          {{ 'customer.order.no_shipping_address' | t }}
        {%- endif -%}
      </div>
      <h2 style="margin-block-start: 2.4rem;">{{ 'customer.order.status' | t }}</h2>
      <div class="address-card">
        {{ 'customer.orders.payment' | t }}: <strong>{{ order.financial_status_label }}</strong><br>
        {{ 'customer.orders.fulfillment' | t }}: <strong>{{ order.fulfillment_status_label }}</strong>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Order",
  "settings": []
}
{% endschema %}
