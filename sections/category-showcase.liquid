<section class="section-spacing">
  <div class="page-width">
    <div class="section-header reveal">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <span class="section-header__eyebrow">{{ section.settings.eyebrow | escape }}</span>
        {%- endif -%}
        <h2>{{ section.settings.heading | escape }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="section-header__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
      </div>
      <a href="{{ routes.collections_url }}" class="link-arrow">
        {{ 'sections.categories.view_all' | t }}
        {% render 'icon', icon: 'arrow-right' %}
      </a>
    </div>

    <div class="category-grid">
      {%- liquid
        assign has_blocks = false
        if section.blocks.size > 0
          assign has_blocks = true
        endif
      -%}
      {%- if has_blocks -%}
        {%- for block in section.blocks -%}
          {%- assign collection = block.settings.collection -%}
          <a href="{{ collection.url | default: '#' }}" class="category-card reveal" style="--reveal-delay: {{ forloop.index0 | times: 0.06 }}s" {{ block.shopify_attributes }}>
            {%- assign card_image = block.settings.image | default: collection.featured_image -%}
            {%- if card_image != blank -%}
              {{ card_image | image_url: width: 700 | image_tag: loading: 'lazy', widths: '350, 500, 700', sizes: '(min-width: 990px) 25vw, 50vw', alt: collection.title | default: block.settings.title | escape }}
            {%- else -%}
              <div class="category-card__placeholder">
                {{ 'collection-1' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
            <div class="category-card__content">
              <div>
                <h3 class="category-card__title">{{ block.settings.title | default: collection.title | escape }}</h3>
                {%- if collection != blank -%}
                  <span class="category-card__count">{{ 'sections.categories.products_count' | t: count: collection.all_products_count }}</span>
                {%- endif -%}
              </div>
              <span class="category-card__arrow">{% render 'icon', icon: 'arrow-right' %}</span>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for collection in collections limit: 8 -%}
          <a href="{{ collection.url }}" class="category-card reveal" style="--reveal-delay: {{ forloop.index0 | times: 0.06 }}s">
            {%- if collection.featured_image != blank -%}
              {{ collection.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: collection.title | escape }}
            {%- else -%}
              <div class="category-card__placeholder">{{ 'collection-1' | placeholder_svg_tag }}</div>
            {%- endif -%}
            <div class="category-card__content">
              <div>
                <h3 class="category-card__title">{{ collection.title | escape }}</h3>
                <span class="category-card__count">{{ 'sections.categories.products_count' | t: count: collection.all_products_count }}</span>
              </div>
              <span class="category-card__arrow">{% render 'icon', icon: 'arrow-right' %}</span>
            </div>
          </a>
        {%- else -%}
          {%- for i in (1..8) -%}
            <div class="category-card reveal">
              <div class="category-card__placeholder">{{ 'collection-1' | placeholder_svg_tag }}</div>
              <div class="category-card__content">
                <h3 class="category-card__title">{{ 'sections.categories.placeholder' | t }}</h3>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category showcase",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Categories" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by category" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "From inspired fragrances to watches — everything in one place." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Custom title (optional)" },
        { "type": "image_picker", "id": "image", "label": "Custom image (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category showcase",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
