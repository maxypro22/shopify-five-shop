<section class="section-spacing" data-slider>
  <div class="page-width">
    <div class="section-header reveal">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <span class="section-header__eyebrow">{{ section.settings.eyebrow | escape }}</span>
        {%- endif -%}
        <h2>{{ section.settings.heading | escape }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="section-header__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
      </div>
      <div class="slider-nav">
        <button type="button" class="slider-nav__btn" data-slider-prev aria-label="{{ 'general.slider.previous' | t }}">
          {% render 'icon', icon: 'chevron-left' %}
        </button>
        <button type="button" class="slider-nav__btn" data-slider-next aria-label="{{ 'general.slider.next' | t }}">
          {% render 'icon', icon: 'chevron-right' %}
        </button>
      </div>
    </div>

    <div class="featured-products__scroller" data-slider-track>
      {%- liquid
        assign featured = section.settings.collection
      -%}
      {%- if featured != blank and featured.products.size > 0 -%}
        {%- for product in featured.products limit: section.settings.limit -%}
          {% render 'product-card', card_product: product, index: forloop.index0 %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          {% render 'product-card', card_product: empty, index: forloop.index0 %}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if featured != blank -%}
      <div style="text-align: center; margin-block-start: 3.2rem;" class="reveal">
        <a href="{{ featured.url }}" class="btn btn--secondary">
          {{ 'sections.featured.view_collection' | t }}
          {% render 'icon', icon: 'arrow-right' %}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Just dropped" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "New arrivals" },
    { "type": "text", "id": "subtitle", "label": "Subtitle" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    {
      "type": "range",
      "id": "limit",
      "min": 4,
      "max": 12,
      "step": 1,
      "label": "Number of products",
      "default": 8
    }
  ],
  "presets": [
    { "name": "Featured products" }
  ]
}
{% endschema %}
