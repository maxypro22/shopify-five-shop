{%- liquid
  assign menu_count = 0
  for block in section.blocks
    if block.type == 'link_list'
      assign menu_count = menu_count | plus: 1
    endif
  endfor
-%}
<footer class="site-footer" style="--footer-cols: {{ menu_count | at_least: 1 }}">
  <div class="page-width">
    <div class="site-footer__inner">
      <div class="site-footer__brand">
        {%- if settings.logo != blank -%}
          {{ settings.logo | image_url: width: 300 | image_tag: alt: shop.name, loading: 'lazy' }}
        {%- else -%}
          <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" loading="lazy" width="52" height="52">
        {%- endif -%}
        <p>{{ section.settings.brand_text | escape }}</p>
        <div class="social-links">
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">{% render 'icon', icon: 'instagram' %}</a>
          {%- endif -%}
          {%- if settings.social_tiktok != blank -%}
            <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">{% render 'icon', icon: 'tiktok' %}</a>
          {%- endif -%}
          {%- if settings.social_twitter != blank -%}
            <a href="{{ settings.social_twitter }}" target="_blank" rel="noopener" aria-label="X">{% render 'icon', icon: 'twitter' %}</a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">{% render 'icon', icon: 'facebook' %}</a>
          {%- endif -%}
          {%- if settings.social_snapchat != blank -%}
            <a href="{{ settings.social_snapchat }}" target="_blank" rel="noopener" aria-label="Snapchat">{% render 'icon', icon: 'snapchat' %}</a>
          {%- endif -%}
          {%- if settings.social_whatsapp != blank -%}
            <a href="{{ settings.social_whatsapp }}" target="_blank" rel="noopener" aria-label="WhatsApp">{% render 'icon', icon: 'whatsapp' %}</a>
          {%- endif -%}
          {%- if settings.social_youtube != blank -%}
            <a href="{{ settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube">{% render 'icon', icon: 'youtube' %}</a>
          {%- endif -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_list' -%}
            <nav {{ block.shopify_attributes }} aria-label="{{ block.settings.heading | escape }}">
              <h3 class="site-footer__heading">{{ block.settings.heading | escape }}</h3>
              <ul class="site-footer__menu">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
                {%- endfor -%}
              </ul>
            </nav>
          {%- when 'newsletter' -%}
            <div class="site-footer__newsletter" {{ block.shopify_attributes }}>
              <h3 class="site-footer__heading">{{ block.settings.heading | escape }}</h3>
              <p>{{ block.settings.text | escape }}</p>
              {%- form 'customer', class: 'footer-newsletter' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                {%- if form.posted_successfully? -%}
                  <p class="form-status form-status--success">{{ 'newsletter.success' | t }}</p>
                {%- else -%}
                  <div class="newsletter-form">
                    <input type="email" name="contact[email]" required placeholder="{{ 'newsletter.placeholder' | t }}" aria-label="{{ 'newsletter.placeholder' | t }}" autocomplete="email">
                    <button type="submit" class="btn btn--primary btn--sm">{{ 'newsletter.submit' | t }}</button>
                  </div>
                {%- endif -%}
              {%- endform -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'sections.footer.rights' | t }}</span>
      <ul class="site-footer__policies">
        {%- for policy in shop.policies -%}
          {%- if policy != blank -%}
            <li><a href="{{ policy.url }}">{{ policy.title | escape }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand description",
      "default": "Premium fashion, fragrances, watches and more — delivered across Qatar."
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu column",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Quick links" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Stay in the loop" },
        { "type": "text", "id": "text", "label": "Text", "default": "Be first to hear about new drops and exclusive offers." }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_list", "settings": { "heading": "Shop" } },
      { "type": "link_list", "settings": { "heading": "Support" } },
      { "type": "newsletter" }
    ]
  }
}
{% endschema %}
