<!doctype html>
<html lang="{{ request.locale.iso_code }}" data-theme="dark">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ shop.name }}</title>
    {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&family=Tajawal:wght@400;500;800&display=swap" rel="stylesheet">
    {% style %}
      :root {
        --color-accent: {{ settings.color_accent | default: '#4f46e5' }};
        --color-accent-rgb: {{ settings.color_accent | default: '#4f46e5' | color_to_rgb | remove: 'rgb(' | remove: ')' }};
        --page-width: 1280px;
        --font-body: 'Plus Jakarta Sans', 'Tajawal', system-ui, sans-serif;
        --font-heading: var(--font-body);
      }
    {% endstyle %}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'sections.css' | asset_url | stylesheet_tag }}
    {{ content_for_header }}
  </head>
  <body>
    {{ content_for_layout }}
  </body>
</html>
